{
  "name": "@aikuora/cli",
  "version": "0.1.0",
  "description": "A compiled TypeScript CLI for monorepo management with Moon + Proto",
  "type": "module",
  "bin": {
    "aikuora": "./dist/index.js"
  },
  "files": [
    "dist",
    "tools"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "monorepo",
    "cli",
    "moonrepo",
    "prototools",
    "scaffold",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "fs-extra": "^11.2.0",
    "handlebars": "^4.7.8",
    "ink": "^5.0.1",
    "meow": "^13.2.0",
    "react": "^18.3.1",
    "yaml": "^2.4.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.19",
    "@types/react": "^18.3.12",
    "prettier": "^3.8.1",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.29.3"
}
